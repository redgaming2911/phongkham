{
  "name": "phong-kham-mini",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:test": "vite preview --port 4173",

    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:business": "vitest run tests/business",
    "test:coverage": "vitest run --coverage",

    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",

    "test:all": "npm run test:unit && npm run test:business && npm run test:e2e",

    "ci:install": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@playwright/test": "^1.45.0"
  }
}